<Window x:Class="DesktopMascot.BubbleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MascotChat"
        Width="340" Height="460"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Border Background="White"
            CornerRadius="14"
            BorderBrush="#D0D0D0"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="2" Opacity="0.18"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- タイトルバー -->
                <RowDefinition Height="40"/>
                <!-- 会話履歴 -->
                <RowDefinition Height="*"/>
                <!-- 入力エリア -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- タイトルバー (Step 3) -->
            <Border Grid.Row="0"
                    Background="#5B8DEF"
                    CornerRadius="14,14,0,0">
                <Grid>
                    <TextBlock Text="🐱 マスコットチャット"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0"/>
                    <Button Content="✕"
                            Click="Close_Click"
                            HorizontalAlignment="Right"
                            Margin="0,0,8,0"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="14"
                            Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- 会話履歴エリア (Step 6) -->
            <ScrollViewer Grid.Row="1"
                          x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Padding="10,8">
                <ItemsControl x:Name="ChatHistory">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- メッセージバブル -->
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- ユーザーメッセージ (右寄せ) -->
                                <Border Grid.Column="1"
                                        Visibility="{Binding IsUser, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Background="#5B8DEF"
                                        CornerRadius="12,4,12,12"
                                        Padding="10,6"
                                        MaxWidth="220">
                                    <TextBlock Text="{Binding Text}"
                                               Foreground="White"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <!-- マスコット返答 (左寄せ) -->
                                <Border Grid.Column="0"
                                        Visibility="{Binding IsUser, Converter={StaticResource BoolToInversedVisibilityConverter}}"
                                        Background="#F0F0F0"
                                        CornerRadius="4,12,12,12"
                                        Padding="10,6"
                                        MaxWidth="220"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Text}"
                                               Foreground="#333333"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 入力エリア (Step 3) -->
            <Border Grid.Row="2"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0"
                    Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="InputBox"
                             Grid.Column="0"
                             FontSize="13"
                             Padding="8,6"
                             BorderBrush="#CCCCCC"
                             BorderThickness="1"
                             AcceptsReturn="False"
                             KeyDown="InputBox_KeyDown"
                             VerticalContentAlignment="Center"
                             Height="36">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Text}" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                    <VisualBrush.Visual>
                                                        <Label Content="メッセージを入力…" Foreground="#AAAAAA" FontSize="12"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <Button x:Name="SendButton"
                            Grid.Column="1"
                            Content="送信"
                            Click="Send_Click"
                            Width="56"
                            Height="36"
                            Margin="6,0,0,0"
                            Background="#5B8DEF"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="12"
                            FontWeight="Bold"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

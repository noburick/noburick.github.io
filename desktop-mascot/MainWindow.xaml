<Window x:Class="DesktopMascot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopMascot"
        Width="200" Height="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Left="100" Top="100"
        ResizeMode="NoResize">

    <Grid>
        <!-- キャラクター画像 (Step 1) -->
        <Image x:Name="CharacterImage"
               Stretch="Uniform"
               Cursor="Hand"
               ToolTip="右クリックでメニューを開く" />

        <!-- 右クリックコンテキストメニュー -->
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="💬 チャットを開く" Click="OpenChat_Click" FontSize="13"/>
                <Separator/>
                <MenuItem Header="📌 最前面固定" Click="ToggleTopmost_Click" x:Name="TopmostMenuItem" IsChecked="True" FontSize="13"/>
                <Separator/>
                <MenuItem Header="❌ 終了" Click="Exit_Click" FontSize="13"/>
            </ContextMenu>
        </Grid.ContextMenu>
    </Grid>

</Window>
